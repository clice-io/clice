{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build/Debug",
        "-G",
        "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/cmake/toolchain.cmake",
        "-DCLICE_ENABLE_TEST=ON"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build Debug",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "${workspaceFolder}/build/Debug"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "cmake: configure Debug",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: configure RelWithDebInfo",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build/RelWithDebInfo",
        "-G",
        "Ninja",
        "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
        "-DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/cmake/toolchain.cmake",
        "-DCLICE_ENABLE_TEST=ON"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: build RelWithDebInfo",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "${workspaceFolder}/build/RelWithDebInfo"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "cmake: configure RelWithDebInfo",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "npm: install vscode deps",
      "type": "shell",
      "command": "pnpm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/editors/vscode"
      },
      "problemMatcher": []
    },
    {
      "label": "npm: watch vscode ext",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "watch"],
      "options": {
        "cwd": "${workspaceFolder}/editors/vscode"
      },
      "dependsOn": "npm: install vscode deps",
      "problemMatcher": "$ts-webpack-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never",
        "group": "watchers"
      }
    },
    {
      "label": "npm: package vscode ext",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "package"],
      "options": {
        "cwd": "${workspaceFolder}/editors/vscode"
      },
      "dependsOn": "npm: install vscode deps",
      "problemMatcher": []
    }
  ]
}
